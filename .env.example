# Build-time secrets for the image sync (scripts/sync-images.ts).
# Copy to .env at the repo root and fill in. .env is gitignored.

# Cloudflare R2 — image hosting for the warframe item/mod icons.
# Mirrors DE PublicExport + wiki images into our own bucket, served via
# img.arsenyx.com. See scripts/sync-images.ts for the sync flow.

R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="arsenyx-images"
R2_PUBLIC_URL="https://img.arsenyx.com"
