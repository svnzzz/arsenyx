generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  runtime  = "workerd"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// AUTH (Better Auth required tables)
// =============================================================================

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?

  username        String? @unique
  displayUsername String?
  bio             String?

  defaultBuildVisibility BuildVisibility @default(PUBLIC)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  isVerified        Boolean @default(false)
  isCommunityLeader Boolean @default(false)
  isModerator       Boolean @default(false)
  isAdmin           Boolean @default(false)
  isBanned          Boolean @default(false)

  accounts                Account[]
  sessions                Session[]
  builds                  Build[]
  likes                   BuildLike[]
  bookmarks               BuildBookmark[]
  apiKeys                 ApiKey[]
  organizationMemberships OrganizationMember[]
  rateLimitWindows        UserRateLimitWindow[]

  @@map("users")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

// =============================================================================
// ORGANIZATIONS
// =============================================================================

enum OrgRole {
  ADMIN
  MEMBER
}

model Organization {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  image       String?
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members OrganizationMember[]
  builds  Build[]

  @@map("organizations")
}

model OrganizationMember {
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  role     OrgRole  @default(MEMBER)
  joinedAt DateTime @default(now())

  @@id([organizationId, userId])
  @@index([userId])
  @@map("organization_members")
}

// =============================================================================
// BUILDS
// =============================================================================

enum BuildVisibility {
  PUBLIC
  PRIVATE
  UNLISTED
}

model Build {
  id   String @id @default(cuid())
  slug String @unique

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  // When true and the build is published under an organization, the
  // author's handle is suppressed in card / detail UI. No effect on
  // solo (no-org) builds — the author is the only attribution there.
  hideAuthor Boolean @default(false)

  // Denormalized item reference (DE uniqueName + category)
  itemUniqueName String
  itemCategory   String
  itemName       String
  itemImageName  String?

  name        String
  description String?
  visibility  BuildVisibility @default(PUBLIC)

  // Full build configuration: slots, mods, arcanes, shards, reactor, forma, etc.
  buildData Json

  hasShards Boolean @default(false)
  hasGuide  Boolean @default(false)

  // Forma count is a projection of buildData (slot forma polarities) + the
  // item's innate polarities (game catalog). Computed client-side at save
  // time and stored here so the list endpoint can show/sort it without
  // shipping buildData. `formaCalcVersion` records which derivation produced
  // it (0 = never computed, e.g. pre-backfill rows) so a calc fix can target
  // only stale rows; `catalogVersion` records the game-data snapshot it was
  // computed against. See packages/shared/warframe/forma.ts + recompute-forma.ts.
  formaCount       Int     @default(0)
  formaCalcVersion Int     @default(0)
  catalogVersion   String?

  // Maintained by Postgres trigger, not Prisma
  searchVector Unsupported("tsvector")?

  likeCount     Int @default(0)
  bookmarkCount Int @default(0)
  viewCount     Int @default(0)

  forkedFromId String?
  forkedFrom   Build?  @relation("BuildForks", fields: [forkedFromId], references: [id], onDelete: SetNull)
  forks        Build[] @relation("BuildForks")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  likes         BuildLike[]
  bookmarks     BuildBookmark[]
  linkedFrom    BuildLink[]     @relation("LinkedFromBuild")
  linkedTo      BuildLink[]     @relation("LinkedToBuild")
  // Symmetric self-M:N. Prisma requires declaring both sides of a self
  // relation; the app maintains symmetry by writing both directions on
  // every connect / disconnect (see partner routes in builds.ts), so
  // `partneredBy` is intentionally unused at the query layer.
  partnerBuilds Build[]         @relation("PartnerBuilds")
  partneredBy   Build[]         @relation("PartnerBuilds")

  buildGuide BuildGuide?

  @@index([userId])
  @@index([itemUniqueName])
  @@index([visibility])
  @@index([likeCount])
  @@index([createdAt])
  @@index([formaCount])
  @@index([visibility, likeCount])
  @@index([visibility, createdAt])
  @@index([userId, visibility])
  @@index([itemUniqueName, visibility, likeCount])
  @@index([hasGuide])
  @@index([forkedFromId])
  @@index([organizationId])
  @@index([organizationId, visibility])
  @@index([userId, visibility, likeCount])
  @@index([itemCategory, visibility, likeCount])
  @@map("builds")
}

model BuildGuide {
  id      String @id @default(cuid())
  buildId String @unique
  build   Build  @relation(fields: [buildId], references: [id], onDelete: Cascade)

  summary     String? @db.VarChar(400)
  description String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("build_guides")
}

model BuildLink {
  id String @id @default(cuid())

  fromBuildId String
  fromBuild   Build  @relation("LinkedFromBuild", fields: [fromBuildId], references: [id], onDelete: Cascade)

  toBuildId String
  toBuild   Build  @relation("LinkedToBuild", fields: [toBuildId], references: [id], onDelete: Cascade)

  label     String?
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())

  @@unique([fromBuildId, toBuildId])
  @@index([fromBuildId])
  @@index([toBuildId])
  @@map("build_links")
}

// =============================================================================
// SOCIAL FEATURES
// =============================================================================

model BuildLike {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  buildId String
  build   Build  @relation(fields: [buildId], references: [id], onDelete: Cascade)

  value Int @default(1)

  createdAt DateTime @default(now())

  @@unique([userId, buildId])
  @@index([buildId])
  @@map("build_likes")
}

model BuildBookmark {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  buildId String
  build   Build  @relation(fields: [buildId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, buildId])
  @@index([buildId])
  @@map("build_bookmarks")
}

// =============================================================================
// USER API KEYS
// =============================================================================

model ApiKey {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String
  key       String @unique
  keyPrefix String

  scopes String[]

  rateLimit Int @default(60)

  isActive   Boolean   @default(true)
  lastUsedAt DateTime?

  createdAt DateTime  @default(now())
  expiresAt DateTime?

  rateLimitWindows ApiKeyRateLimitWindow[]

  @@index([userId])
  @@map("api_keys")
}

model ApiKeyRateLimitWindow {
  apiKeyId String
  apiKey   ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  windowStart  DateTime
  requestCount Int      @default(0)

  @@id([apiKeyId, windowStart])
  @@index([windowStart])
  @@map("api_key_rate_limit_windows")
}

// Per-user rate-limit windows for cookie-session mutations. Bucketed by action
// kind ("mutate", "social", "import") so different tiers share one table.
// Pruned opportunistically by the limiter middleware (see api-key-auth.ts
// pattern). Same best-effort, racy semantics — fine for abuse throttling, not
// for hard quotas.
model UserRateLimitWindow {
  userId      String
  bucket      String
  windowStart DateTime

  requestCount Int @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, bucket, windowStart])
  @@index([windowStart])
  @@map("user_rate_limit_windows")
}
