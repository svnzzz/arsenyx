# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# vite
/apps/*/dist
/apps/*/.vite

# tanstack router generated
/apps/web/src/routeTree.gen.ts

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# typescript
*.tsbuildinfo

# wrangler
.wrangler/
.dev.vars

# prisma generated files
/apps/api/src/generated/

# rust crates (local experiments — dps-calc target, etc.)
/crates/

# claude temp files
.claude/
.agents/
skills-lock.json
.superpowers/
docs/superpowers/
