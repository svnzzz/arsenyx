# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# vite
/apps/*/dist
/apps/*/.vite

# tanstack router generated
/apps/web/src/routeTree.gen.ts

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# typescript
*.tsbuildinfo

# Upstream data mirror — DE PublicExport JSON + wiki Lua, re-fetched from the
# network by `bun run data:sync` (scripts/sync-de.ts, sync-wiki.ts). Pure
# pipeline input: neither CI nor the deploy reads it — only the weekly
# `data:bump` job, which re-downloads it first. The built catalog under
# apps/web/public/data/ IS committed and is what actually ships. Fresh clones
# run `bun run data:sync` before rebuilding the catalog locally.
/data/raw/

# diff-index regression snapshots — a local scratch copy of a known-good
# apps/web/public/data/ build, never committed (it's a duplicate of generated
# output). See scripts/diff-index.ts. golden-v2 is the current snapshot dir.
/data/golden/
/data/golden-v2/

# wrangler
.wrangler/
.dev.vars

# prisma generated files
/apps/api/src/generated/

# rust crates (local experiments — dps-calc target, etc.)
/crates/

# claude temp files
.claude/
.agents/
skills-lock.json
.superpowers/
docs/superpowers/
/plans/
