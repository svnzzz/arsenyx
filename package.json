{
  "name": "arsenyx-monorepo",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "bun --filter=arsenyx-web run dev",
    "dev:api": "bun --filter=arsenyx-api run dev",
    "build:web": "bun --filter=arsenyx-web run build",
    "build:items": "bun run scripts/build-items-index.ts",
    "sync:images": "bun run scripts/sync-images.ts",
    "check:images": "bun run scripts/check-image-hosts.ts",
    "data:sync": "bun run scripts/sync-de.ts && bun run scripts/sync-wiki.ts",
    "data:bump": "bun run scripts/bump-data.ts",
    "typecheck": "bun run --filter '*' typecheck && bun run typecheck:scripts",
    "typecheck:scripts": "bunx tsc --noEmit -p scripts/tsconfig.json",
    "lint": "oxlint apps/web/src apps/api/src packages/shared/src",
    "lint:fix": "oxlint --fix apps/web/src apps/api/src packages/shared/src",
    "fmt": "oxfmt --write apps/web/src apps/api/src packages/shared/src '!**/generated/**' '!**/*.gen.ts' '!**/components/ui/**'",
    "fmt:check": "oxfmt --check apps/web/src apps/api/src packages/shared/src '!**/generated/**' '!**/*.gen.ts' '!**/components/ui/**'"
  },
  "dependencies": {
    "@arsenyx/shared": "workspace:*",
    "nanoid": "^5.1.11"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/luaparse": "^0.2.12",
    "aws4fetch": "^1.0.20",
    "concurrently": "^9.2.1",
    "luaparse": "^0.3.1",
    "lzma": "^2.3.2",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.62.0",
    "warframe-public-export-plus": "^0.6.1"
  }
}
